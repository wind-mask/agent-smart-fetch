{
  "name": "@thinkscape/smart-fetch",
  "version": "0.3.8",
  "type": "module",
  "description": "Smart web fetch CLI with desktop-browser TLS impersonation and defuddle extraction.",
  "license": "MIT",
  "author": "Thinkscape",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thinkscape/agent-smart-fetch.git"
  },
  "homepage": "https://github.com/Thinkscape/agent-smart-fetch#readme",
  "bugs": {
    "url": "https://github.com/Thinkscape/agent-smart-fetch/issues"
  },
  "keywords": [
    "smart-fetch",
    "defuddle",
    "wreq-js",
    "content-extraction",
    "web-fetch",
    "tls-fingerprinting",
    "cli"
  ],
  "main": "./dist/cli.js",
  "bin": {
    "smart-fetch": "./dist/cli.js",
    "sf": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bunx tsup --config tsup.config.ts",
    "test": "bun test test",
    "typecheck": "bunx tsc -p tsconfig.json",
    "check": "bun run test && bun run build && bun run typecheck",
    "pack:dry-run": "bun run build && npm pack --dry-run"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "wreq-js": "^2.3.1",
    "defuddle": "^0.18.1",
    "linkedom": "^0.18.12",
    "mime-types": "^3.0.2",
    "lodash": "^4.18.1"
  }
}
