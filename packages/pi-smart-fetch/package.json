{
  "name": "pi-smart-fetch",
  "version": "0.2.29",
  "type": "module",
  "description": "Smart web_fetch with desktop-browser TLS impersonation and defuddle extraction.",
  "license": "MIT",
  "author": "Thinkscape",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thinkscape/agent-smart-fetch.git"
  },
  "homepage": "https://github.com/Thinkscape/agent-smart-fetch#readme",
  "bugs": {
    "url": "https://github.com/Thinkscape/agent-smart-fetch/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "smart-fetch",
    "defuddle",
    "wreq-js",
    "content-extraction",
    "web-fetch",
    "tls-fingerprinting"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "image": "https://raw.githubusercontent.com/Thinkscape/agent-smart-fetch/master/packages/pi-smart-fetch/demo.gif"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bunx tsup --config tsup.config.ts",
    "test": "bun test test/unit",
    "typecheck": "bunx tsc -p tsconfig.json",
    "check": "bun run test && bun run build && bun run typecheck",
    "pack:dry-run": "bun run build && npm pack --dry-run"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.66.1",
    "@sinclair/typebox": "^0.34.49",
    "wreq-js": "^2.3.0",
    "defuddle": "^0.16.0",
    "linkedom": "^0.18.12"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  }
}
