{
  "name": "agent-smart-fetch",
  "private": true,
  "version": "0.3.7",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "description": "Bun monorepo for smart web fetching across pi and OpenClaw.",
  "license": "MIT",
  "author": "Thinkscape",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thinkscape/agent-smart-fetch.git"
  },
  "homepage": "https://github.com/Thinkscape/agent-smart-fetch#readme",
  "bugs": {
    "url": "https://github.com/Thinkscape/agent-smart-fetch/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "image": "https://raw.githubusercontent.com/Thinkscape/agent-smart-fetch/master/packages/pi-smart-fetch/demo.gif"
  },
  "scripts": {
    "clean": "find packages -type d \\( -name dist -o -name coverage \\) -prune -exec rm -rf {} +",
    "clean:all": "bun run clean && rm -rf coverage dist",
    "build": "bun run build:core && bun run build:pi && bun run build:openclaw && bun run build:cli",
    "build:core": "cd packages/core && bun run build",
    "build:pi": "cd packages/pi-smart-fetch && bun run build",
    "build:openclaw": "cd packages/openclaw-smart-fetch && bun run build",
    "build:cli": "cd packages/smart-fetch && bun run build",
    "test": "bun run test:core && bun run test:pi && bun run test:openclaw && bun run test:cli",
    "test:core": "cd packages/core && bun run test",
    "test:pi": "cd packages/pi-smart-fetch && bun run test",
    "test:openclaw": "cd packages/openclaw-smart-fetch && bun run test",
    "test:cli": "cd packages/smart-fetch && bun run test",
    "test:integration": "cd packages/core && bun run test:integration",
    "coverage": "cd packages/core && bun run coverage",
    "lint": "bunx biome check . && bun run typecheck",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "typecheck": "bun run typecheck:core && bun run typecheck:pi && bun run typecheck:openclaw && bun run typecheck:cli",
    "verify:clean-install": "bun run scripts/verify-clean-install.ts",
    "typecheck:core": "cd packages/core && bun run typecheck",
    "typecheck:pi": "cd packages/pi-smart-fetch && bun run typecheck",
    "typecheck:openclaw": "cd packages/openclaw-smart-fetch && bun run typecheck",
    "typecheck:cli": "cd packages/smart-fetch && bun run typecheck",
    "check": "bun run lint && bun run test && bun run build && bun run pack:smoke:all",
    "check:core": "cd packages/core && bun run check",
    "check:pi": "cd packages/pi-smart-fetch && bun run check",
    "check:openclaw": "cd packages/openclaw-smart-fetch && bun run check",
    "check:cli": "cd packages/smart-fetch && bun run check",
    "pack:dry-run": "bun run pack:dry-run:all",
    "pack:dry-run:all": "bun run pack:dry-run:pi && bun run pack:dry-run:openclaw && bun run pack:dry-run:cli",
    "pack:smoke:all": "bun run pack:smoke:pi && bun run pack:smoke:openclaw && bun run pack:smoke:cli",
    "pack:dry-run:core": "cd packages/core && bun run pack:dry-run",
    "pack:dry-run:pi": "cd packages/pi-smart-fetch && bun run pack:dry-run",
    "pack:dry-run:openclaw": "cd packages/openclaw-smart-fetch && bun run pack:dry-run",
    "pack:dry-run:cli": "cd packages/smart-fetch && bun run pack:dry-run",
    "pack:smoke:pi": "bun run scripts/pack-install-smoke.ts packages/pi-smart-fetch",
    "pack:smoke:openclaw": "bun run scripts/pack-install-smoke.ts packages/openclaw-smart-fetch",
    "pack:smoke:cli": "bun run scripts/pack-install-smoke.ts packages/smart-fetch",
    "publish:pi": "npm publish --workspace packages/pi-smart-fetch --access public",
    "publish:openclaw": "npm publish --workspace packages/openclaw-smart-fetch --access public",
    "publish:cli": "npm publish --workspace packages/smart-fetch --access public",
    "publish:all": "bun run publish:pi && bun run publish:openclaw && bun run publish:cli",
    "version:patch": "bun run scripts/version.ts patch",
    "version:minor": "bun run scripts/version.ts minor",
    "version:major": "bun run scripts/version.ts major",
    "release": "bun run scripts/release.ts auto",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major",
    "detect-latest-chrome": "bun run scripts/detect-chrome.ts",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@types/bun": "^1.3.14",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "defuddle": "^0.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
